#include <stdio.h>
#define INF 9999
int main()
{
    int n, i, j, src;
    int cost[10][10], dist[10], visited[10];
    printf("Enter number of routers: ");
    scanf("%d", &n);
    printf("Enter the cost matrix (9999 for no link):\n");
    for (i = 0; i < n; i++)
    {
        for (j = 0; j < n; j++)
        {
            scanf("%d", &cost[i][j]);
        }
    }
    printf("Enter source router (0 to %d): ", n - 1);
    scanf("%d", &src);
    for (i = 0; i < n; i++)
    {
        dist[i] = cost[src][i];
        visited[i] = 0;
    }
    dist[src] = 0;
    visited[src] = 1;
    for (i = 1; i < n; i++)
    {
        int min = INF, u = -1;
 
        for (j = 0; j < n; j++)
        {
            if (!visited[j] && dist[j] < min)
            {
                min = dist[j];
                u = j;
            }
        }
        visited[u] = 1;
        for (j = 0; j < n; j++)
        {
            if (!visited[j] && dist[u] + cost[u][j] < dist[j])
            {
                dist[j] = dist[u] + cost[u][j];
            }
        }
    }
    printf("\nShortest paths from router %d:\n", src);
    for (i = 0; i < n; i++)
    {
        printf("To router %d : %d\n", i, dist[i]);
    }
    return 0;
}
